{
	"compilerOptions": {
		"module": "nodenext",
		"esModuleInterop": true,
		"target": "esnext",
		"noImplicitAny": true,
		"moduleResolution": "nodenext",
		"sourceMap": true,
		"outDir": "dist",
		"strict": true,
		"jsxImportSource": "react",
		"jsx": "react-jsx",
		"noEmit": true,
		"skipLibCheck": true,
		"typeRoots": ["types/", "node_modules/@types"],
		"paths": {
			"test/*": ["./test/*"],
			"lib/*": ["./lib/*"]
		}
	},
	"include": ["lib/**/*.ts", "test/**/*.ts"],
	"exclude": ["node_modules"]
}
